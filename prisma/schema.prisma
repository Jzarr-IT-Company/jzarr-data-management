generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  NOT_INTERESTED
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  role                 UserRole
  status               UserStatus @default(ACTIVE)
  phone                String?   @unique
  designation          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  managedDepartments    Department[] @relation("ManagedDepartments")
  createdLeads          Lead[]    @relation("CreatedLeads")
  updatedLeads          Lead[]    @relation("UpdatedLeads")
  createdStores         Store[]   @relation("CreatedStores")
  updatedStores         Store[]   @relation("UpdatedStores")
  createdStoreStats     StoreStat[] @relation("CreatedStoreStats")
  updatedStoreStats     StoreStat[] @relation("UpdatedStoreStats")
  leadActivities        LeadActivity[]
  refreshTokens         RefreshToken[]
}

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  accent      String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  managers    User[]    @relation("ManagedDepartments")
  leads       Lead[]
  stores      Store[]
}

model Lead {
  id                String      @id @default(cuid())
  referenceNo       String      @unique
  name              String
  fatherName        String?
  email             String?
  phone             String      @unique
  whatsapp          String?
  city              String?
  address           String?
  message           String?
  status            LeadStatus  @default(NEW)
  departmentId      String
  createdById       String?
  updatedById       String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  department        Department  @relation(fields: [departmentId], references: [id])
  createdBy         User?       @relation("CreatedLeads", fields: [createdById], references: [id])
  updatedBy         User?       @relation("UpdatedLeads", fields: [updatedById], references: [id])
  activities        LeadActivity[]

  @@index([departmentId, status])
}

model LeadActivity {
  id          String    @id @default(cuid())
  leadId      String
  userId      String?
  action      String
  note        String?
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

model Store {
  id            String      @id @default(cuid())
  departmentId   String
  name          String
  url           String
  isActive      Boolean     @default(true)
  createdById   String?
  updatedById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation("CreatedStores", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?       @relation("UpdatedStores", fields: [updatedById], references: [id], onDelete: SetNull)
  stats         StoreStat[]

  @@unique([departmentId, name])
  @@unique([departmentId, url])
  @@index([departmentId, isActive])
}

model StoreStat {
  id            String      @id @default(cuid())
  storeId       String
  statDate      DateTime
  views         Int         @default(0)
  visitors      Int         @default(0)
  orders        Int         @default(0)
  revenue       Decimal     @default(0)
  createdById   String?
  updatedById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation("CreatedStoreStats", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?       @relation("UpdatedStoreStats", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([storeId, statDate])
  @@index([storeId, statDate])
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
