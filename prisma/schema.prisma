generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  passwordHash       String
  role               UserRole
  status             UserStatus     @default(ACTIVE)
  phone              String?        @unique
  designation        String?
  managerId          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  allowedScreens     Json?
  manager            User?          @relation("ManagerTeam", fields: [managerId], references: [id], onDelete: SetNull)
  createdLeads       Lead[]         @relation("CreatedLeads")
  updatedLeads       Lead[]         @relation("UpdatedLeads")
  leadActivities     LeadActivity[]
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  createdStores      Store[]        @relation("CreatedStores")
  updatedStores      Store[]        @relation("UpdatedStores")
  createdStoreStats  StoreStat[]    @relation("CreatedStoreStats")
  updatedStoreStats  StoreStat[]    @relation("UpdatedStoreStats")
  createdTasks       Task[]         @relation("CreatedTasks")
  assignedTasks      Task[]         @relation("AssignedTasks")
  updatedTasks       Task[]         @relation("UpdatedTasks")
  managedDepartments Department[]   @relation("ManagedDepartments")
  teamUsers          User[]         @relation("ManagerTeam")

  @@index([managerId])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  accent    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
  stores    Store[]
  tasks     Task[]
  managers  User[]   @relation("ManagedDepartments")
}

model Lead {
  id           String         @id @default(cuid())
  referenceNo  String         @unique
  name         String
  fatherName   String?
  email        String?
  phone        String         @unique
  whatsapp     String?
  city         String?
  address      String?
  message      String?
  status       LeadStatus     @default(NEW)
  departmentId String
  createdById  String?
  updatedById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdBy    User?          @relation("CreatedLeads", fields: [createdById], references: [id])
  department   Department     @relation(fields: [departmentId], references: [id])
  updatedBy    User?          @relation("UpdatedLeads", fields: [updatedById], references: [id])
  activities   LeadActivity[]

  @@index([departmentId, status])
  @@index([createdById], map: "Lead_createdById_fkey")
  @@index([updatedById], map: "Lead_updatedById_fkey")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  action    String
  note      String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([leadId, createdAt])
  @@index([userId], map: "LeadActivity_userId_fkey")
}

model Store {
  id           String      @id @default(cuid())
  departmentId String
  name         String
  url          String
  isActive     Boolean     @default(true)
  createdById  String?
  updatedById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    User?       @relation("CreatedStores", fields: [createdById], references: [id])
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  updatedBy    User?       @relation("UpdatedStores", fields: [updatedById], references: [id])
  stats        StoreStat[]

  @@unique([departmentId, name])
  @@unique([departmentId, url])
  @@index([departmentId, isActive])
  @@index([createdById], map: "Store_createdById_fkey")
  @@index([updatedById], map: "Store_updatedById_fkey")
}

model StoreStat {
  id          String   @id @default(cuid())
  storeId     String
  statDate    DateTime
  views       Int      @default(0)
  visitors    Int      @default(0)
  orders      Int      @default(0)
  revenue     Decimal  @default(0.000000000000000000000000000000)
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("CreatedStoreStats", fields: [createdById], references: [id])
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation("UpdatedStoreStats", fields: [updatedById], references: [id])

  @@unique([storeId, statDate])
  @@index([storeId, statDate])
  @@index([createdById], map: "StoreStat_createdById_fkey")
  @@index([updatedById], map: "StoreStat_updatedById_fkey")
}

model Task {
  id            String         @id @default(cuid())
  title         String
  description   String
  managerId     String
  departmentId  String
  status        TaskStatus     @default(TODO)
  priority      TaskPriority   @default(MEDIUM)
  startDate     DateTime
  dueDate       DateTime
  notes         String?
  createdById   String?
  updatedById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
  createdBy     User?          @relation("CreatedTasks", fields: [createdById], references: [id])
  department    Department     @relation(fields: [departmentId], references: [id])
  manager       User           @relation("AssignedTasks", fields: [managerId], references: [id])
  updatedBy     User?          @relation("UpdatedTasks", fields: [updatedById], references: [id])

  @@index([managerId, status])
  @@index([departmentId, status])
  @@index([dueDate])
  @@index([createdById], map: "Task_createdById_fkey")
  @@index([updatedById], map: "Task_updatedById_fkey")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  taskId    String?
  type      String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  task      Task?     @relation(fields: [taskId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([taskId], map: "Notification_taskId_fkey")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

enum UserRole {
  ADMIN
  MANAGER
  MANAGER_USER
  SUB_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  NOT_INTERESTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
