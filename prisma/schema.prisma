generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  NOT_INTERESTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  role                 UserRole
  status               UserStatus @default(ACTIVE)
  phone                String?   @unique
  designation          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  managedDepartments    Department[] @relation("ManagedDepartments")
  createdLeads          Lead[]    @relation("CreatedLeads")
  updatedLeads          Lead[]    @relation("UpdatedLeads")
  createdStores         Store[]   @relation("CreatedStores")
  updatedStores         Store[]   @relation("UpdatedStores")
  createdStoreStats     StoreStat[] @relation("CreatedStoreStats")
  updatedStoreStats     StoreStat[] @relation("UpdatedStoreStats")
  assignedTasks         Task[]    @relation("AssignedTasks")
  createdTasks          Task[]    @relation("CreatedTasks")
  updatedTasks          Task[]    @relation("UpdatedTasks")
  leadActivities        LeadActivity[]
  refreshTokens         RefreshToken[]
  notifications         Notification[]
}

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  accent      String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  managers    User[]    @relation("ManagedDepartments")
  leads       Lead[]
  stores      Store[]
  tasks       Task[]
}

model Lead {
  id                String      @id @default(cuid())
  referenceNo       String      @unique
  name              String
  fatherName        String?
  email             String?
  phone             String      @unique
  whatsapp          String?
  city              String?
  address           String?
  message           String?
  status            LeadStatus  @default(NEW)
  departmentId      String
  createdById       String?
  updatedById       String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  department        Department  @relation(fields: [departmentId], references: [id])
  createdBy         User?       @relation("CreatedLeads", fields: [createdById], references: [id])
  updatedBy         User?       @relation("UpdatedLeads", fields: [updatedById], references: [id])
  activities        LeadActivity[]

  @@index([departmentId, status])
}

model LeadActivity {
  id          String    @id @default(cuid())
  leadId      String
  userId      String?
  action      String
  note        String?
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

model Store {
  id            String      @id @default(cuid())
  departmentId   String
  name          String
  url           String
  isActive      Boolean     @default(true)
  createdById   String?
  updatedById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation("CreatedStores", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?       @relation("UpdatedStores", fields: [updatedById], references: [id], onDelete: SetNull)
  stats         StoreStat[]

  @@unique([departmentId, name])
  @@unique([departmentId, url])
  @@index([departmentId, isActive])
}

model StoreStat {
  id            String      @id @default(cuid())
  storeId       String
  statDate      DateTime
  views         Int         @default(0)
  visitors      Int         @default(0)
  orders        Int         @default(0)
  revenue       Decimal     @default(0)
  createdById   String?
  updatedById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation("CreatedStoreStats", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?       @relation("UpdatedStoreStats", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([storeId, statDate])
  @@index([storeId, statDate])
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String
  managerId     String
  departmentId  String
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  startDate     DateTime
  dueDate       DateTime
  notes         String?
  createdById   String?
  updatedById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  manager       User         @relation("AssignedTasks", fields: [managerId], references: [id], onDelete: Restrict)
  department    Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  createdBy     User?        @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?        @relation("UpdatedTasks", fields: [updatedById], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([managerId, status])
  @@index([departmentId, status])
  @@index([dueDate])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  taskId      String?
  type        String
  title       String
  message     String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
