{
  "name": "jzarr-data-manage-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:render": "node dist/src/server.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "npm run prisma:migrate:dev",
    "prisma:migrate:dev": "tsx scripts/prisma-run.ts development migrate dev",
    "prisma:migrate:deploy": "tsx scripts/prisma-run.ts production migrate deploy",
    "prisma:generate:dev": "tsx scripts/prisma-run.ts development generate",
    "prisma:generate:deploy": "tsx scripts/prisma-run.ts production generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node script/seedRunner.js development",
    "prisma:seed:dev": "node script/seedRunner.js development",
    "prisma:seed:deploy": "node script/seedRunner.js production"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "globals": "^16.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.24.1"
  }
}
